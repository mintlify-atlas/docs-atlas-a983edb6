  "keyFeatures": [
    "RAG-based semantic search using FAISS vector store",
    "Gemini 1.5 Flash LLM integration for intelligent candidate analysis",
    "Automated CV generation and parsing for testing",
    "Structured data extraction from resumes with Pydantic models",
    "Reverse matching approach prioritizing projects and potential over experience",
    "HuggingFace embeddings for semantic similarity",
    "Batch processing and talent mining capabilities",
    "Interactive visualization with Plotly"
  ],
  "publicApiSurface": [
    "ChatGoogleGenerativeAI - Gemini 1.5 Flash LLM wrapper",
    "HuggingFaceEmbeddings - Sentence transformer embeddings",
    "FAISS.from_documents() - Vector store creation",
    "PyPDFLoader - PDF document loader",
    "JsonOutputParser - Structured data extraction",
    "PerfilEstudiante - Student profile Pydantic model",
    "ChatPromptTemplate - Prompt template system",
    "RunnablePassthrough - LangChain chain composition"
